{
  "name": "@gdggye/backend-core",
  "version": "0.1.0",
  "private": true,
  "description": "Domain + application layers for the GDG Guayaquil platform. Zero infrastructure imports — no Supabase, no Next.js.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./events": "./src/application/use-cases/events/index.ts",
    "./identity": "./src/application/use-cases/identity/index.ts",
    "./consents": "./src/application/use-cases/consents/index.ts",
    "./registrations": "./src/application/use-cases/registrations/index.ts",
    "./sponsors": "./src/application/use-cases/sponsors/index.ts",
    "./event-sponsors": "./src/application/use-cases/event-sponsors/index.ts",
    "./speakers": "./src/application/use-cases/speakers/index.ts",
    "./event-speakers": "./src/application/use-cases/event-speakers/index.ts",
    "./agenda": "./src/application/use-cases/agenda/index.ts",
    "./leaderboard": "./src/application/use-cases/leaderboard/index.ts",
    "./pre-checkin": "./src/application/use-cases/pre-checkin/index.ts",
    "./activities": "./src/application/use-cases/activities/index.ts",
    "./scans": "./src/application/use-cases/scans/index.ts",
    "./domain": "./src/domain/index.ts",
    "./ports": "./src/application/ports/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@gdggye/config": "*",
    "@types/node": "^20",
    "typescript": "^5",
    "vitest": "^2.1.4"
  }
}
